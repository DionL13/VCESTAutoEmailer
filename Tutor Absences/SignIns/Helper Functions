function colLettertoColNumber(columnLetter){
  // Function converts column letter to a column number, only for columns A-Z. These are the columns of the ARRAY form of the sheets!! NOT the column of the sheets themselves!!

  let alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".slice();
  let colNumber = alphabet.indexOf(columnLetter); // matches indexing of array 

  return colNumber;
}

function colNumbertoColLetter(columnNumber){
  // Function converts column number to a column letter, only for columns A-Z

  let alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".slice();
  let colLetter = alphabet[columnNumber-1]; // -1 accounts for indexing from 0 and columns beginning at 1

  return colLetter;
}


function createFormForClassCover(className, block, noTutorsClasses, potentialCoversCodes, tutorCode){
  // Function creates a new Google Form sheet with the name of the class (including unique identifier) + "Class Cover". This sheet then links to the Class Covers spreadsheet as a single sheet within the spreadsheet, tracking the tutors' responses to the form. Once the form has a successful cover for all classes, the form is deleted and the tutors are notified of a confirmation. The tutors who respond after will get an automated response saying that a class cover was found, OR will no longer take responses with a message saying a class cover was found. 

  let form = FormApp.create(className + ' Class Cover', true); // creates a form to be published

  // Setting form properties by chaining (applying same properties to form in succession)
  form.setDescription('Please select the blocks you can cover. If you cannot cover any of the classes, please select the "None" option')
    .setConfirmationMessage('Thank you for your response. If you are the first respondant who can cover a class, you will receive an automated email confirmation from Ops shortly. If your availability changes and you can no longer cover a class, please email Ops as soon as possible.')
    .setAllowResponseEdits(false)
    .setCustomClosedFormMessage("A class cover has been found for all requested blocks. If you are seeing this message after submitting the form, your response was NOT logged as a cover has already been found for the classes you submitted.");


  // Setting questions for Tutor Code and tutor name so that the tutor can be added to the sign in sheet
  const tutorCodeItem = form.addTextItem();
  tutorCodeItem.setRequired(true);
  tutorCodeItem.setTitle('What is your tutor code?');

  const tutorNameItem = form.addTextItem();
  tutorNameItem.setRequired(true);
  tutorNameItem.setTitle('What is your first name?');

  // Setting questions for classes to be covered
  const item = form.addCheckboxItem();
  item.setRequired(true);
  item.setTitle('Which block(s) can you cover?');

  let blockPlusClasses = noTutorsClasses.map(x => block + x); // New array which maps the absentClasses array to an array with every element having the block variable appended before the class
  blockPlusClasses.push("None"); // Adds "None" to the end of the array, returns the new length of the array

  item.setChoiceValues(blockPlusClasses); // Sets possible values as blocks and classes, and None as the last option

  // Setting form response destination to the sheet
  form.setDestination(FormApp.DestinationType.SPREADSHEET, formResponsesSheetId); // Sets responses to go into a new sheet in spreadsheet
  SpreadsheetApp.flush(); // Updates form before getting most recent sheet

  newSheet = ssFormResponses.getSheets()[0]; // Gets most recently created sheet
  newSheet.setTabColor('yellow'); // Sets colour of tab to the "New" colour

  // Setting name to be the name of the class, if there are duplicates, set the name as the name of the class + (i), where i is the next unused integer
  let sheetName = ""; 
  let idx = 1;
  try{ // If no other sheets share the same name, won't throw an error
    newSheet.setName(className);
    sheetName = className;
  } 
  catch(error){
    let numSheets = ssFormResponses.getNumSheets();
    while (sheetName == ""){ // Running on each duplicate index
      let numSameName = 0;
      for (let i = 0; i < numSheets; i+=1){ // Checking if any of the sheets have the same name 
        if (ssFormResponses.getSheets()[i].getName() == className + " (" + idx + ")"){
          numSameName += 1;
        } 
      }
      
      if (numSameName == 0){
        newSheet.setName(className + " (" + idx + ")");
        sheetName = className + " (" + idx + ")";
      }
      else if (numSameName > 0){
        idx += 1;
      }
    }
  } 

  // Getting form link
  let formLink = form.shortenFormUrl(form.getPublishedUrl());

  // Adding form link to sheet
  newSheet.getRange('F2').setFormula('=HYPERLINK("' + formLink + '" , "Form Link")');

  // Adding option to contact urgent covers
  newSheet.getRange('H1').setValue("Contact Urgent Covers?");
  newSheet.getRange('I1').insertCheckboxes(); // Adds a checkbox under the question
  newSheet.getRange('H1:I1').setBackground('#9933ff').setFontColor('white');

  // Setting cell F1 (outside of form responses) to the blocks which need to be covered as a storage mechanism
  newSheet.getRange('F1').setValue('Classes with no tutors: ' + blockPlusClasses.slice(0,-1).join(",")); // Not including "None"
  newSheet.getRange('F1:G1').setBackground('#0099ff').setFontColor('white');

  // Listing which tutors have been contacted in cells in the F column
  newSheet.getRange('F3').setValue("Contacted Tutors")
  newSheet.getRange('F3:G3').setBackground('#00ffff');

  // Adding absent tutor code to form responses sheet for storage 
  newSheet.getRange('J1').setValue("Absent Tutor Code: " + tutorCode);

  let potentialCoversCodesForSetVals = potentialCoversCodes.map(element => [element]);

  if (potentialCoversCodes.length > 0){
    let lastRow = 4 + (potentialCoversCodes.length - 1); // Inputs start from 4th row. If 1 element, input tutor code into 4th row
    newSheet.getRange('F4:F' + lastRow).setValues(potentialCoversCodesForSetVals);
  }

  // Updating Property 
  let newClassesValueString = statusProperties.getProperty('newClassesKey'); // Accesses string version of current value associated with the key
  let newClassesValueArray = JSON.parse(newClassesValueString); // Converts string extracted from key-value pair into a JavaScript object (namely an array)

  newClassesValueArray.push(sheetName + " - " + block); // Updating "new" array. No double-ups on names occur because each sheet name only exists once. Automatically accounts for duplicates in creating sheet name

  statusProperties.setProperty('newClassesKey', JSON.stringify(newClassesValueArray)); // Updating key-value pair. Both key and value must be strings

  let temporaryArrayForSetVals = newClassesValueArray.map(element => [element]); // setValues() requires a 2D array of the form of the data, so setting values down a column requires [[A],[B],[C]] not [A,B,C] which would be for elements in the same row. The split() is so the classes written to the sheet don't have duplicate indices attached but these indices remain in statusProperties

  // Updating Daily Status Sheet
  let endRow = 3 + temporaryArrayForSetVals.length - 1; // Starting from row 3, -1 since when there's only 1 element in "New", want endRow = 3
  statusSheet.getRange("A3:A" + endRow).setValues(temporaryArrayForSetVals);

  return [formLink, sheetName];
}



function initializeStatusProperty(){
  // Using Property service to store a property type (key-value pairs like a dict) between executions globally 
  const statusProperties = PropertiesService.getScriptProperties();

  if (statusProperties.getProperty('newClassesKey') === null && statusProperties.getProperty('ongoingClassesKey') === null && statusProperties.getProperty('coveredClassesKey') === null){ // Only setting new properties if they don't already exist (getProperty() returns null if doesn't exist)
    let newProperties = { // Values need to be stored as strings
      newClassesKey : '[]',
      ongoingClassesKey : '[]',
      coveredClassesKey: '[]',
    }
    statusProperties.setProperties(newProperties); // Sets the above properties as key-value pairs'
  }

  console.log("statusProperties :", statusProperties.getProperties());
  return statusProperties;
}

const statusProperties = initializeStatusProperty();

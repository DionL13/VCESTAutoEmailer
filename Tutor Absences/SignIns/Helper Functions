  let msgHtml = ""; // initialising message to be updated inside if statement

  for (let i = 0; i < potentialCovers.length; i+=1){
    let address = potentialCovers[i][1]; // No direct address, only bcc's
    if (teamTutor == false){ // default condition
      msgHtml = 

      "Hi " + potentialCovers[i][0] + "," + 


      MailApp.sendEmail(address, subject, msgPlain, {htmlBody: msgHtml}); // htmlBody formats body as an html text 
    }
    else if (teamTutor == true){
      msgHtml = 

      "Hi " + potentialCovers[i][0] + "," +

      "<p> We are looking for a tutor to cover " + subjectName + " for class(es)</p>" + 
      
